<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>{% block title %}Dondrekiel App{% endblock %}</title>

    <link href="//fonts.googleapis.com/css?family=Saira+Extra+Condensed:100,200,300,400,500,600,700,800,900"
          rel="stylesheet">
    <link href="//fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i,800,800i"
          rel="stylesheet">

    {% stylesheets
    '@DondrekielWebBundle/Resources/public/vendor/bootstrap/css/bootstrap.css'
    '@DondrekielWebBundle/Resources/public/vendor/font-awesome/css/font-awesome.css'
    '@DondrekielWebBundle/Resources/public/vendor/devicons/css/devicons.min.css'
    '@DondrekielWebBundle/Resources/public/vendor/simple-line-icons/css/simple-line-icons.css'
    '@DondrekielWebBundle/Resources/public/css/resume.min.css' %}
    <link rel="stylesheet" href="{{ asset_url }}" type="text/css"/>
    {% endstylesheets %}
</head>

<body id="page-top">

{% block body %}{% endblock %}

{% javascripts
'%kernel.root_dir%/../vendor/components/jquery/jquery.js'
'%kernel.root_dir%/../vendor/twitter/bootstrap/dist/js/bootstrap.js'
'@DondrekielWebBundle/Resources/public/vendor/jquery-easing/jquery.easing.min.js'
'@DondrekielWebBundle/Resources/public/js/resume.min.js' %}
<script type="text/javascript" src="{{ asset_url }}"></script>
{% endjavascripts %}

</body>
</html>





