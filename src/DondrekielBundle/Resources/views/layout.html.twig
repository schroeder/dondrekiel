<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <title>{% block title %}Dondrekiel App{% endblock %}</title>
    {% stylesheets
    '%kernel.root_dir%/../vendor/twitter/bootstrap/dist/css/bootstrap.css'
    '%kernel.root_dir%/../vendor/twitter/bootstrap/dist/css/bootstrap-theme.css'
    '@DondrekielBundle/Resources/public/css/dondrekiel.css' %}
    <link rel="stylesheet" href="{{ asset_url }}" type="text/css"/>
    {% endstylesheets %}
<body>


{{ include('DondrekielBundle::/parts/navigation.html.twig') }}


<div class="container map-container">
    <div class="jumbotron">
        {% block body %}{% endblock %}
    </div>
</div>


<script type="text/javascript">
    var app_hostname = "{{ app_hostname }}";
    var wss_enabled = {{ wss_enabled }};
</script>

{% if wss_enabled %}
    {{ ws_client() }}
{% endif %}


{% javascripts '@jquery' '@bootstrap_js' %}
<script type="text/javascript" src="{{ asset_url }}"></script>
{% endjavascripts %}
<script async defer
        src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBL6W6MTPZ1XsY1k2lNWqzRqr7sTPHoeTk">
</script>
<script src="https://rawgit.com/asmsuechan/jquery_push_notification/master/push_notification.min.js"></script>

</body>
</html>